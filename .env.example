# Kandidatentekort Automation - Environment Variables
# Copy to .env and fill in values

# Required
ANTHROPIC_API_KEY=sk-ant-xxxxx
PIPEDRIVE_API_TOKEN=REMOVED_PIPEDRIVE_TOKEN

# Resend Email Service (https://resend.com) — REQUIRED
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@kandidatentekort.nl

# Gmail (deprecated — Resend is recommended)
# GMAIL_USER=wouter@recruitin.nl
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Jotform Webhook Security (required for signature verification)
# Get from: Jotform Dashboard > Settings > API section (your API key)
JOTFORM_WEBHOOK_SECRET=your_jotform_api_key_here

# Server
PORT=8080
