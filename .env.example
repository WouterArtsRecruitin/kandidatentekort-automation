# Kandidatentekort Automation - Environment Variables
# Copy to .env and fill in values

# Required
ANTHROPIC_API_KEY=sk-ant-xxxxx
PIPEDRIVE_API_TOKEN=REMOVED_PIPEDRIVE_TOKEN

# Resend Email Service (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@kandidatentekort.nl
RESEND_FROM_NAME=Kandidatentekort

# Optional: Different sender addresses for different email types
RESEND_REPORTS_EMAIL=rapporten@kandidatentekort.nl
RESEND_NOTIFICATIONS_EMAIL=notificaties@kandidatentekort.nl
RESEND_SUPPORT_EMAIL=support@kandidatentekort.nl

# Test email for verification
TEST_EMAIL=your-email@example.com

# OLD Gmail SMTP (deprecated - use Resend instead)
# GMAIL_USER=wouter@recruitin.nl
# GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Jotform Webhook Security (NEW - required for signature verification)
# Get from: Jotform Dashboard > Settings > API Key > Copy your API key
JOTFORM_WEBHOOK_SECRET=your_jotform_api_key_here

# Jotform Webhook Security (NEW - required for signature verification)
# Get from: Jotform Dashboard > Settings > API Key > Copy your API key
JOTFORM_WEBHOOK_SECRET=your_jotform_api_key_here

# Server
PORT=8080
